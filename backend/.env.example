NODE_ENV=production
PORT=5000

DB_HOST=127.0.0.1
DB_USER=radiology_app
DB_PASSWORD=CHANGE_TO_A_STRONG_DATABASE_PASSWORD
DB_NAME=radiology_db

# Generate with: npm run security:generate-secret
JWT_SECRET=CHANGE_TO_A_RANDOM_SECRET_OF_AT_LEAST_48_CHARACTERS
JWT_EXPIRES_IN=8h

# Comma-separated HTTPS origins only. Do not include paths or a trailing slash.
FRONTEND_URL=https://radiology.example.org

# Set according to the reverse proxy topology. "1" is typical for one trusted proxy.
TRUST_PROXY=1
ENFORCE_HTTPS=true

# Required only when seeding a new production database.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_TO_A_UNIQUE_STRONG_INITIAL_PASSWORD
